# Server
PORT=9714
BASE_URL=http://localhost:9714
API_BASE_URL=http://localhost:9712

# Database
DATABASE_URL=postgres://kittypaw:kittypaw@localhost:5432/kittypaw_api?sslmode=disable

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional local E2E/fake OAuth overrides. Leave unset in normal dev/prod.
# GOOGLE_AUTH_URL=http://localhost:9901/o/oauth2/v2/auth
# GOOGLE_TOKEN_URL=http://localhost:9901/token
# GOOGLE_USERINFO_URL=http://localhost:9901/userinfo
CONNECT_BASE_URL=http://localhost:9714
CONNECT_GOOGLE_CLIENT_ID=
CONNECT_GOOGLE_CLIENT_SECRET=
CONNECT_X_CLIENT_ID=
CONNECT_X_CLIENT_SECRET=
# Optional local E2E/fake Connect OAuth overrides. Leave unset in normal dev/prod.
# CONNECT_GOOGLE_AUTH_URL=http://localhost:9901/o/oauth2/v2/auth
# CONNECT_GOOGLE_TOKEN_URL=http://localhost:9901/token
# CONNECT_GOOGLE_USERINFO_URL=http://localhost:9901/userinfo
# CONNECT_X_AUTH_URL=http://localhost:9902/i/oauth2/authorize
# CONNECT_X_TOKEN_URL=http://localhost:9902/2/oauth2/token
# CONNECT_X_USERINFO_URL=http://localhost:9902/2/users/me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT RS256 signing key. Standard base64 of a PEM-encoded RSA private key.
# Generate a dev key with: openssl genrsa 2048 | base64 -w0
JWT_PRIVATE_KEY_PEM_B64=

# CORS - comma-separated origins (defaults to BASE_URL)
# CORS_ORIGINS=https://portal.kittypaw.app,https://chat.kittypaw.app

# Web OAuth redirect_uri allowlist. Empty disables the web flow.
# WEB_REDIRECT_URI_ALLOWLIST=https://chat.kittypaw.app/auth/callback

# Discovery targets
# KAKAO_RELAY_URL=https://kakao.kittypaw.app
# CHAT_RELAY_URL=https://chat.kittypaw.app
# SKILLS_REGISTRY_URL=https://github.com/kittypaw-app/skills
